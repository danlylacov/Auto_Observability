# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auto_observability

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# External Services URLs (Docker service names)
PROMETHEUS_GENERATION_URL=http://prometheus_generation:8000
DOCKER_API_URL=http://docker_api:8000
PROMETHEUS_MANAGER_URL=http://prometheus_manager:8000
DOCKER_CLASSIFICATION_API_URL=http://docker_classification:8000

# MinIO Configuration
MINIO_ENDPOINT=http://minio:9000
MINIO_USR=minioadmin
MINIO_PWD=minioadmin
