# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/auto_observability

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=True

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_USR=minioadmin
MINIO_PWD=minioadmin

# External Services URLs
PROMETHEUS_GENERATION_URL=http://prometheus_generation:8000
DOCKER_API_URL=http://docker_api:8000
PROMETHEUS_MANAGER_URL=http://prometheus_manager:8000
DOCKER_CLASSIFICATION_API_URL=http://docker_classification:8000

# Application
DEBUG=False
